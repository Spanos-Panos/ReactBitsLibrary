{
  "name": "reactbitscursor",
  "version": "0.1.1",
  "description": "ReactBits Component Explorer & Playground Generator",
  "main": "electron/main.cjs",
  "homepage": "https://github.com/Spanos-Panos/ReactBitsLibrary",
  "repository": {
    "type": "git",
    "url": "https://github.com/Spanos-Panos/ReactBitsLibrary.git"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "generate:manifest": "node scripts/generate-manifest.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "cross-env NODE_ENV=production electron .",
    "build:electron": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.reactbits.explorer",
    "productName": "ReactBits Explorer",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Spanos-Panos",
        "repo": "ReactBitsLibrary"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "DemoCLI/**/*",
      "ReactBitsComponents/**/*",
      "src/reactbits-manifest.json",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "images/ReactBitsGallery.png"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@google/generative-ai": "^0.24.1",
    "@react-three/fiber": "^9.5.0",
    "@types/three": "^0.183.1",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "gsap": "^3.14.2",
    "ogl": "^1.0.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
